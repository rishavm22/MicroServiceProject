# MicroConfigServer - Git-backed config server credentials
CONFIG_SERVER_GIT_URI=https://github.com/rishavm22/MicroServiceProject-MicroConfigServer
CONFIG_SERVER_GIT_USERNAME=your-github-username
CONFIG_SERVER_GIT_PASSWORD=your-github-pat

# APIGateway - JWT secret for token validation (must match UserAccountService's signing key)
JWT_SECRET=your-base64-encoded-jwt-secret

# UserAccountService - Gateway IP whitelist (restrict /users/** to gateway only)
GATEWAY_IP=your-gateway-ip
